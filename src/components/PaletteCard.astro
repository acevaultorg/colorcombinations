---
import type { Palette } from "@/types/palette";

export interface Props {
  palette: Palette;
  /** Heading level for card title (h2 on home, h3 on browse) */
  headingLevel?: "h2" | "h3";
}

const { palette, headingLevel = "h3" } = Astro.props;
const Tag = headingLevel;
---

<article class="plate palette-card">
  <a href={`/palettes/${palette.slug}`} class="palette-card__link" aria-label={`View ${palette.title} palette`}>
    <div class="palette-card__swatches" role="img" aria-label={`${palette.colors.length} color palette`}>
      {palette.colors.map((color) => (
        <span
          class="palette-card__swatch"
          style={`background-color: ${color.hex};`}
          title={color.nameRomaji ? `${color.nameRomaji} — ${color.hex}` : color.hex}
        />
      ))}
    </div>

    <div class="palette-card__body">
      <p class="eyebrow">{palette.era.charAt(0).toUpperCase() + palette.era.slice(1)} era</p>
      <Tag class="palette-card__title">
        {palette.title}
        {palette.titleJa && <span class="title-ja">— {palette.titleJa}</span>}
      </Tag>
      <p class="palette-card__summary">{palette.summary}</p>
    </div>
  </a>
</article>

<style>
  .palette-card {
    display: block;
  }

  .palette-card__link {
    display: flex;
    flex-direction: column;
    height: 100%;
    color: inherit;
    text-decoration: none;
  }

  .palette-card__link:hover .palette-card__title {
    color: var(--color-accent-500);
  }

  .palette-card__swatches {
    display: flex;
    width: 100%;
    aspect-ratio: 4 / 3;
    border-bottom: 1px solid var(--color-border);
  }

  .palette-card__swatch {
    flex: 1;
    transition: flex 180ms ease;
  }

  /* Hover: the largest swatch bumps a bit — subtle, not a SaaS wiggle */
  .palette-card__link:hover .palette-card__swatch:first-child {
    flex: 1.15;
  }

  .palette-card__body {
    padding: 1.25rem 1.25rem 1.5rem;
  }

  .palette-card__title {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 500;
    line-height: 1.2;
    margin: 0.375rem 0 0.5rem;
    color: var(--color-ink-900);
    transition: color 150ms ease;
    letter-spacing: -0.01em;
  }

  .palette-card__title .title-ja {
    font-size: 0.85em;
    font-weight: 400;
    color: var(--color-ink-500);
  }

  .palette-card__summary {
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-500);
    margin: 0;
    max-width: none;
  }
</style>
