---
import BaseLayout from "@layouts/BaseLayout.astro";
import PaletteCard from "@components/PaletteCard.astro";
import FurtherReading from "@components/FurtherReading.astro";
import BundleCta from "@components/BundleCta.astro";
import { FURTHER_READING } from "@/config/monetization";
import { allColors, colorBySlug, palettesForColor } from "@data/colors";
import { bestTextColorOn, contrastRatio } from "@/lib/color";
import type { HexColor } from "@/types/palette";

export function getStaticPaths() {
  return allColors().map((c) => ({ params: { slug: c.slug } }));
}

const { slug } = Astro.params;
const color = colorBySlug(slug ?? "");

if (!color) {
  return Astro.redirect("/404");
}

const palettes = palettesForColor(color);
const textColor = bestTextColorOn(color.hex);

// Contrast examples: what this color looks like against white and black
const onWhite = contrastRatio(color.hex, "#FFFFFF" as HexColor);
const onBlack = contrastRatio(color.hex, "#000000" as HexColor);

// Deterministic book rotation
const bookOffset =
  color.slug
    .split("")
    .reduce((sum, ch) => sum + ch.charCodeAt(0), 0) % FURTHER_READING.length;

const displayName = color.name + (color.nameJa ? ` (${color.nameJa})` : "");
const title = displayName;
const description = color.meaning
  ? `${color.name} — ${color.meaning}. Hex ${color.hex}. Found in ${color.paletteCount} historical color combination${color.paletteCount === 1 ? "" : "s"} from Sanzo Wada's 1933 dictionary.`
  : `${color.name} — hex ${color.hex}. Found in ${color.paletteCount} historical color combination${color.paletteCount === 1 ? "" : "s"} from Sanzo Wada's 1933 Dictionary of Color Combinations.`;

const keywords = [
  color.name,
  color.nameJa,
  color.hex,
  `${color.name} hex`,
  `${color.name} color`,
  `${color.hue} color`,
  "Sanzo Wada",
  "color combination",
  "Japanese color",
].filter(Boolean) as string[];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CreativeWork",
    name: color.name,
    alternateName: color.nameJa,
    description,
    url: new URL(`/colors/${color.slug}`, Astro.site).toString(),
    keywords: keywords.join(", "),
    color: color.hex,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: new URL("/", Astro.site).toString(),
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Colors",
        item: new URL("/colors", Astro.site).toString(),
      },
      {
        "@type": "ListItem",
        position: 3,
        name: color.name,
      },
    ],
  },
];
---

<BaseLayout title={title} description={description} keywords={keywords} jsonLd={jsonLd}>
  <nav class="breadcrumb container-wide" aria-label="Breadcrumb">
    <ol>
      <li><a href="/">Home</a></li>
      <li aria-hidden="true">&#x203A;</li>
      <li><a href="/colors/">Colors</a></li>
      <li aria-hidden="true">&#x203A;</li>
      <li aria-current="page">{color.name}</li>
    </ol>
  </nav>

  <section class="color-hero">
    <div class="container-wide color-hero__inner">
      <div
        class="color-hero__swatch"
        style={`background-color:${color.hex}`}
        role="img"
        aria-label={`Color swatch: ${color.name} ${color.hex}`}
      >
        <span class={`color-hero__hex ${textColor === "dark" ? "text-dark" : "text-light"}`}>
          {color.hex}
        </span>
      </div>

      <div class="color-hero__info">
        <p class="eyebrow">{color.hue} &middot; {color.paletteCount} palette{color.paletteCount === 1 ? "" : "s"}</p>
        <h1 class="display-hero text-balance">{color.name}</h1>
        {color.nameJa && <p class="color-hero__ja">{color.nameJa}</p>}
        {color.meaning && <p class="color-hero__meaning">{color.meaning}</p>}
      </div>
    </div>
  </section>

  <section class="color-details section">
    <div class="container-wide color-details__grid">
      <div class="color-details__main">
        <h2 class="section-title">Palettes with {color.name}</h2>
        <p class="color-details__intro">
          {color.name} appears in {color.paletteCount} combination{color.paletteCount === 1 ? "" : "s"} from
          the archive. {color.paletteCount > 1 ? "Each pairing reveals how the same color shifts character depending on its neighbours." : ""}
        </p>
        <div class="palette-grid" role="list">
          {palettes.map((palette) => (
            <div role="listitem">
              <PaletteCard palette={palette} headingLevel="h3" />
            </div>
          ))}
        </div>
      </div>

      <aside class="color-details__sidebar">
        <div class="color-spec">
          <h2 class="spec-title">Specifications</h2>
          <dl class="spec-list">
            <div class="spec-row">
              <dt>Hex</dt>
              <dd><code>{color.hex}</code></dd>
            </div>
            <div class="spec-row">
              <dt>RGB</dt>
              <dd><code>{parseInt(color.hex.slice(1, 3), 16)}, {parseInt(color.hex.slice(3, 5), 16)}, {parseInt(color.hex.slice(5, 7), 16)}</code></dd>
            </div>
            <div class="spec-row">
              <dt>Hue family</dt>
              <dd>{color.hue}</dd>
            </div>
            <div class="spec-row">
              <dt>On white</dt>
              <dd>{onWhite.toFixed(1)}:1 {onWhite >= 4.5 ? "AA" : onWhite >= 3 ? "AA large" : "decorative"}</dd>
            </div>
            <div class="spec-row">
              <dt>On black</dt>
              <dd>{onBlack.toFixed(1)}:1 {onBlack >= 4.5 ? "AA" : onBlack >= 3 ? "AA large" : "decorative"}</dd>
            </div>
            <div class="spec-row">
              <dt>Palettes</dt>
              <dd>{color.paletteCount}</dd>
            </div>
          </dl>
        </div>

        <div class="color-copy">
          <h2 class="spec-title">Quick copy</h2>
          <div class="copy-buttons">
            <button class="copy-btn" data-copy={color.hex} aria-label={`Copy hex ${color.hex}`}>
              Hex
            </button>
            <button
              class="copy-btn"
              data-copy={`rgb(${parseInt(color.hex.slice(1, 3), 16)}, ${parseInt(color.hex.slice(3, 5), 16)}, ${parseInt(color.hex.slice(5, 7), 16)})`}
              aria-label="Copy RGB value"
            >
              RGB
            </button>
            <button
              class="copy-btn"
              data-copy={`--color-${color.slug}: ${color.hex};`}
              aria-label="Copy CSS custom property"
            >
              CSS var
            </button>
          </div>
        </div>

        <FurtherReading variant="sidebar" offset={bookOffset} />
      </aside>
    </div>
  </section>

  <BundleCta variant="medium" />
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>(".copy-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const text = btn.dataset.copy ?? "";
      try {
        await navigator.clipboard.writeText(text);
        const original = btn.textContent;
        btn.textContent = "Copied!";
        btn.classList.add("copied");
        setTimeout(() => {
          btn.textContent = original;
          btn.classList.remove("copied");
        }, 1500);
      } catch {
        // Fallback for older browsers
        const input = document.createElement("input");
        input.value = text;
        document.body.appendChild(input);
        input.select();
        document.execCommand("copy");
        document.body.removeChild(input);
      }
    });
  });
</script>

<style>
  .breadcrumb {
    padding-top: 1.5rem;
  }

  .breadcrumb ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-ink-500);
  }

  .breadcrumb a {
    color: var(--color-ink-500);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-accent-500);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .breadcrumb li[aria-current="page"] {
    color: var(--color-ink-900);
  }

  /* ============ HERO ============ */

  .color-hero {
    padding-top: 2rem;
    padding-bottom: clamp(2rem, 5vw, 4rem);
  }

  .color-hero__inner {
    display: flex;
    gap: 2.5rem;
    align-items: flex-start;
    max-width: 62rem;
  }

  @media (max-width: 640px) {
    .color-hero__inner {
      flex-direction: column;
      gap: 1.5rem;
    }
  }

  .color-hero__swatch {
    width: clamp(6rem, 15vw, 10rem);
    height: clamp(6rem, 15vw, 10rem);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 0.75rem;
    flex-shrink: 0;
  }

  .color-hero__hex {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .text-dark { color: rgba(0, 0, 0, 0.7); }
  .text-light { color: rgba(255, 255, 255, 0.85); }

  .color-hero__info {
    flex: 1;
    min-width: 0;
  }

  .color-hero .eyebrow {
    margin-bottom: 1rem;
    text-transform: capitalize;
  }

  .color-hero__ja {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--color-ink-500);
    margin-top: 0.5rem;
  }

  .color-hero__meaning {
    font-family: var(--font-serif);
    font-size: clamp(1.0625rem, 1.2vw + 0.75rem, 1.25rem);
    font-style: italic;
    line-height: 1.55;
    color: var(--color-ink-700);
    margin-top: 1rem;
    max-width: 58ch;
  }

  /* ============ DETAILS ============ */

  .color-details__grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 3rem;
    align-items: start;
  }

  @media (max-width: 900px) {
    .color-details__grid {
      grid-template-columns: 1fr;
    }
  }

  .section-title {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 1.5vw + 0.75rem, 1.5rem);
    line-height: 1.2;
    margin: 0 0 1rem;
  }

  .color-details__intro {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-ink-700);
    margin-bottom: 2rem;
    max-width: 58ch;
  }

  .palette-grid {
    display: grid;
    gap: 1.75rem;
    grid-template-columns: repeat(1, 1fr);
  }

  @media (min-width: 640px) and (max-width: 899px) {
    .palette-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .palette-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ============ SIDEBAR ============ */

  .color-details__sidebar {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .color-spec,
  .color-copy {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
  }

  .spec-title {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink-500);
    margin: 0 0 1rem;
  }

  .spec-list {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .spec-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .spec-row dt {
    font-size: 0.875rem;
    color: var(--color-ink-500);
  }

  .spec-row dd {
    margin: 0;
    font-size: 0.875rem;
    color: var(--color-ink-900);
    text-align: right;
  }

  .spec-row code {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    background: var(--color-paper-100);
    padding: 0.125rem 0.375rem;
    border-radius: 3px;
  }

  /* ============ COPY BUTTONS ============ */

  .copy-buttons {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .copy-btn {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-paper-50);
    color: var(--color-ink-700);
    cursor: pointer;
    transition: border-color 150ms ease, color 150ms ease;
    letter-spacing: 0.03em;
  }

  .copy-btn:hover {
    border-color: var(--color-ink-900);
    color: var(--color-ink-900);
  }

  .copy-btn.copied {
    border-color: var(--color-accent-500);
    color: var(--color-accent-500);
  }
</style>
