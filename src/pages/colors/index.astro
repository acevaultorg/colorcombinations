---
import BaseLayout from "@layouts/BaseLayout.astro";
import { allColors, colorsByHue, type ColorEntry } from "@data/colors";
import { bestTextColorOn } from "@/lib/color";

const colors = allColors();
const grouped = colorsByHue();
const total = colors.length;

const title = "Color Dictionary";
const description = `All ${total} named colors from the archive — browse by hue family, see hex values, and discover which palettes use each color. A complete index of the historical color vocabulary from Sanzo Wada's 1933 Dictionary of Color Combinations.`;

const hueOrder = ["red", "orange", "yellow", "brown", "pink", "green", "blue", "purple", "neutral"] as const;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: title,
    description,
    url: new URL("/colors", Astro.site).toString(),
    isPartOf: {
      "@type": "WebSite",
      name: "The Dictionary of Color Combinations",
      url: Astro.site?.toString(),
    },
    numberOfItems: total,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: new URL("/", Astro.site).toString(),
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Colors",
      },
    ],
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <section class="colors-hero">
    <div class="container-wide colors-hero__inner">
      <p class="eyebrow">{total} named colors</p>
      <h1 class="display-hero text-balance">Color Dictionary.</h1>
      <p class="colors-hero__lede">
        Every named color in the archive — from Hermosa Pink to Cossack Green. Each entry links
        to every palette that uses it, so you can trace one color across the full dictionary.
      </p>
    </div>
  </section>

  <section class="colors-filter section">
    <div class="container-wide">
      <div class="filter-bar" role="toolbar" aria-label="Filter by hue family">
        <button class="filter-pill is-active" data-hue="all">All ({total})</button>
        {hueOrder.map((hue) => {
          const group = grouped.get(hue);
          if (!group || group.length === 0) return null;
          return (
            <button class="filter-pill" data-hue={hue}>
              {hue.charAt(0).toUpperCase() + hue.slice(1)} ({group.length})
            </button>
          );
        })}
      </div>
    </div>
  </section>

  <section class="colors-grid-section section">
    <div class="container-wide">
      <div class="colors-grid" role="list" id="color-grid">
        {colors.map((color) => {
          const text = bestTextColorOn(color.hex);
          return (
            <a
              href={`/colors/${color.slug}/`}
              class="color-tile"
              data-hue={color.hue}
              role="listitem"
              aria-label={`${color.name} — ${color.hex}, in ${color.paletteCount} palette${color.paletteCount === 1 ? "" : "s"}`}
            >
              <div
                class="color-tile__swatch"
                style={`background-color:${color.hex}`}
              >
                <span class={`color-tile__hex ${text === "dark" ? "text-dark" : "text-light"}`}>
                  {color.hex}
                </span>
              </div>
              <div class="color-tile__info">
                <span class="color-tile__name">{color.name}</span>
                {color.nameJa && <span class="color-tile__ja">{color.nameJa}</span>}
                <span class="color-tile__count">{color.paletteCount} palette{color.paletteCount === 1 ? "" : "s"}</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>(".filter-pill");
  const tiles = document.querySelectorAll<HTMLElement>(".color-tile");

  pills.forEach((pill) => {
    pill.addEventListener("click", () => {
      pills.forEach((p) => p.classList.remove("is-active"));
      pill.classList.add("is-active");

      const hue = pill.dataset.hue;
      tiles.forEach((tile) => {
        if (hue === "all" || tile.dataset.hue === hue) {
          tile.style.display = "";
        } else {
          tile.style.display = "none";
        }
      });
    });
  });
</script>

<style>
  .colors-hero {
    padding-top: clamp(3rem, 8vw, 6rem);
    padding-bottom: clamp(2rem, 5vw, 4rem);
  }

  .colors-hero__inner {
    max-width: 62rem;
  }

  .colors-hero .eyebrow {
    margin-bottom: 1.5rem;
  }

  .colors-hero__lede {
    font-family: var(--font-serif);
    font-size: clamp(1.125rem, 1.4vw + 0.75rem, 1.375rem);
    line-height: 1.55;
    color: var(--color-ink-700);
    max-width: 58ch;
    margin-top: 1.75rem;
  }

  /* ============ FILTER BAR ============ */

  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .filter-pill {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 100px;
    background: var(--color-paper-50);
    color: var(--color-ink-700);
    cursor: pointer;
    transition: border-color 150ms ease, color 150ms ease, background 150ms ease;
    letter-spacing: 0.02em;
    text-transform: capitalize;
  }

  .filter-pill:hover {
    border-color: var(--color-ink-900);
    color: var(--color-ink-900);
  }

  .filter-pill.is-active {
    background: var(--color-ink-900);
    color: var(--color-paper-50);
    border-color: var(--color-ink-900);
  }

  /* ============ GRID ============ */

  .colors-grid-section {
    padding-top: 0;
  }

  .colors-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(2, 1fr);
  }

  @media (min-width: 640px) {
    .colors-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 960px) {
    .colors-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (min-width: 1280px) {
    .colors-grid {
      grid-template-columns: repeat(5, 1fr);
    }
  }

  .color-tile {
    display: block;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow-plate);
    transition: transform 200ms ease, box-shadow 200ms ease;
  }

  .color-tile:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-plate-hover);
  }

  .color-tile:focus-visible {
    outline: 2px solid var(--color-accent-500);
    outline-offset: 4px;
  }

  .color-tile__swatch {
    aspect-ratio: 1;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 0.5rem;
  }

  .color-tile__hex {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .text-dark { color: rgba(0, 0, 0, 0.55); }
  .text-light { color: rgba(255, 255, 255, 0.7); }

  .color-tile__info {
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .color-tile__name {
    font-family: var(--font-serif);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-ink-900);
    line-height: 1.25;
  }

  .color-tile__ja {
    font-size: 0.75rem;
    color: var(--color-ink-500);
    font-family: var(--font-serif);
  }

  .color-tile__count {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    color: var(--color-ink-400);
    letter-spacing: 0.05em;
    margin-top: 0.25rem;
  }
</style>
