---
import BaseLayout from "@layouts/BaseLayout.astro";
import { collections, paletteSetForCollection } from "@/data/collections";

const title = "Collections";
const description =
  "Curated groupings of palettes by practical use case — websites, branding, seasonal themes, indigo traditions, Heian court colors, and more. Every collection combines editorial picks with matching plates from the full Sanzo Wada catalog.";

// Pre-compute per-collection preview data at build time.
const collectionData = collections.map((c) => {
  const resolved = paletteSetForCollection(c);
  // Up to 4 preview palettes
  const preview = resolved.slice(0, 4);
  return { collection: c, preview, total: resolved.length };
});

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: title,
    description,
    url: new URL("/collections", Astro.site).toString(),
    isPartOf: {
      "@type": "WebSite",
      name: "The Dictionary of Color Combinations",
      url: Astro.site?.toString(),
    },
    hasPart: collections.map((c) => ({
      "@type": "CreativeWork",
      name: c.title,
      url: new URL(`/collections/${c.slug}`, Astro.site).toString(),
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: new URL("/", Astro.site).toString(),
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Collections",
      },
    ],
  },
];
---

<BaseLayout title={title} description={description} jsonLd={jsonLd}>
  <section class="collections-hero">
    <div class="container-wide collections-hero__inner">
      <p class="eyebrow">Curated groupings</p>
      <h1 class="display-hero text-balance">Collections.</h1>
      <p class="collections-hero__lede">
        Eight ways to browse the archive by what you're actually making. Websites, brands, seasons, traditions. Each collection is a short editorial pick paired with every matching plate from the full Wada catalog.
      </p>
    </div>
  </section>

  <section class="collections-grid section">
    <div class="container-wide">
      <ul class="collections-list" role="list">
        {collectionData.map(({ collection, preview, total }) => (
          <li class="collection-card">
            <a href={`/collections/${collection.slug}`} class="collection-card__link" aria-label={`${collection.title} — ${total} palettes`}>
              <div class="collection-card__swatches" aria-hidden="true">
                {preview.map((p) => (
                  <div class="collection-card__mini">
                    {p.colors.slice(0, 4).map((c) => (
                      <span style={`background:${c.hex}`}></span>
                    ))}
                  </div>
                ))}
              </div>
              <div class="collection-card__body">
                <p class="collection-card__count">{total} palettes</p>
                <h2 class="collection-card__title">{collection.title}</h2>
                <p class="collection-card__tagline">{collection.tagline}</p>
                <p class="collection-card__cta">Browse collection →</p>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>

<style>
  .collections-hero {
    padding-top: clamp(3rem, 8vw, 6rem);
    padding-bottom: clamp(2rem, 5vw, 4rem);
  }

  .collections-hero__inner {
    max-width: 62rem;
  }

  .collections-hero .eyebrow {
    margin-bottom: 1.5rem;
  }

  .collections-hero__lede {
    font-family: var(--font-serif);
    font-size: clamp(1.125rem, 1.4vw + 0.75rem, 1.375rem);
    line-height: 1.55;
    color: var(--color-ink-700);
    max-width: 58ch;
    margin-top: 1.75rem;
  }

  /* ============ GRID ============ */

  .collections-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 720px) {
    .collections-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1100px) {
    .collections-list {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .collection-card {
    display: block;
  }

  .collection-card__link {
    display: block;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow-plate);
    transition:
      transform 200ms ease,
      box-shadow 200ms ease;
    height: 100%;
  }

  .collection-card__link:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-plate-hover);
  }

  .collection-card__link:focus-visible {
    outline: 2px solid var(--color-accent-500);
    outline-offset: 4px;
  }

  .collection-card__swatches {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    height: 8rem;
    gap: 2px;
    background: var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .collection-card__mini {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: 1fr;
  }

  .collection-card__mini span {
    display: block;
    height: 100%;
  }

  .collection-card__body {
    padding: 1.5rem;
  }

  .collection-card__count {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-ink-500);
    margin: 0 0 0.75rem;
  }

  .collection-card__title {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 500;
    line-height: 1.2;
    margin: 0 0 0.75rem;
    color: var(--color-ink-900);
  }

  .collection-card__tagline {
    font-family: var(--font-serif);
    font-size: 0.9375rem;
    line-height: 1.55;
    color: var(--color-ink-700);
    margin: 0 0 1.25rem;
    font-style: italic;
  }

  .collection-card__cta {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-accent-500);
    margin: 0;
    letter-spacing: 0.02em;
  }

  .collection-card__link:hover .collection-card__cta {
    color: var(--color-accent-600);
  }
</style>
