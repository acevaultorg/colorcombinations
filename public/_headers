# Cloudflare Pages _headers file — applied to all responses.
# https://developers.cloudflare.com/pages/configuration/headers/

/*
  # Security headers (OWASP baseline for static site)
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  # No inline scripts except our own (set:html blocks for JSON-LD) — unsafe-inline needed for that.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self' https://forms.example.com

# Long-cache for hashed assets (Astro emits .hash.css, .hash.js)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Long-cache for static images
/favicon.svg
  Cache-Control: public, max-age=86400, must-revalidate

/og-default.svg
  Cache-Control: public, max-age=86400, must-revalidate

# Sitemap + robots should be freshly crawled
/sitemap-index.xml
  Cache-Control: public, max-age=3600
/sitemap-0.xml
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=3600
